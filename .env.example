# Copy to .env and fill in values
BIND_ADDR=0.0.0.0:8080
MAX_PEERS_PER_ROOM=2
RUST_LOG=disintea_server=info
# TURN shared secret (must match coturn's static-auth-secret)
TURN_SECRET=change-me-to-a-random-string
# TURN server URL returned to clients
TURN_URL=turn:161.97.187.145:3478

# web-dist/ is populated by scripts/deploy-web.sh from disintea-client
# certs/ is populated by deploy/gen-self-signed.sh
